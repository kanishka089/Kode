-- ============================================================
-- REFERENCE: Standard Library (all 30+ modules)
-- ============================================================
-- Every built-in function in Kode, organized by module.
-- ============================================================

-- ================================================================
-- io — Input/Output
-- ================================================================
io.out("hello")                -- print to stdout
io.err("error!")               -- print to stderr

-- ================================================================
-- math — Mathematics
-- ================================================================
math.abs(-5)                   -- 5
math.floor(3.7)                -- 3
math.ceil(3.2)                 -- 4
math.round(3.5)                -- 4
math.sqrt(16)                  -- 4
math.random()                  -- 0.0 to 1.0
math.min(3, 7)                 -- 3
math.max(3, 7)                 -- 7
math.pi                        -- 3.14159...
math.e                         -- 2.71828...

-- ================================================================
-- str — String Operations
-- ================================================================
str.upper("hello")             -- HELLO
str.lower("HELLO")             -- hello
str.trim("  hi  ")             -- hi
str.len("hello")               -- 5
str.contains("hello", "ell")   -- tr
str.starts("hello", "hel")     -- tr
str.ends("hello", "llo")       -- tr
str.replace("aab", "a", "x")  -- xxb
str.split("a-b-c", "-")       -- @[a b c]
str.join(@["a" "b"], "-")     -- a-b
str.slice("hello", 1, 3)      -- el

-- ================================================================
-- lst — List Operations
-- ================================================================
lst.map(@[1 2 3], |x| -> x * 2)          -- @[2 4 6]
lst.filter(@[1 2 3 4], |x| -> x > 2)     -- @[3 4]
lst.reduce(@[1 2 3], |a, x| -> a + x, 0) -- 6
lst.find(@[1 2 3], |x| -> x > 1)         -- 2
lst.sort(@[3 1 2])                        -- @[1 2 3]
lst.reverse(@[1 2 3])                     -- @[3 2 1]
lst.unique(@[1 1 2 2])                    -- @[1 2]
lst.chunk(@[1 2 3 4], 2)                  -- @[@[1 2] @[3 4]]
lst.zip(@[1 2], @["a" "b"])              -- @[@[1 a] @[2 b]]
lst.join(@["a" "b"], "-")                -- a-b
lst.flat(@[@[1] @[2 3]])                 -- @[1 2 3]
lst.slice(@[1 2 3 4], 1, 3)             -- @[2 3]
lst.contains(@[1 2 3], 2)               -- tr
lst.len(@[1 2 3])                        -- 3
lst.push(@[1 2], 3)                      -- adds 3 (mutates)
lst.pop(@[1 2 3])                        -- removes last

-- ================================================================
-- mp — Map Operations
-- ================================================================
mp.keys(@{a|1 b|2})           -- @[a b]
mp.values(@{a|1 b|2})         -- @[1 2]
mp.has(@{a|1}, "a")           -- tr
mp.len(@{a|1 b|2})            -- 2

-- ================================================================
-- json — JSON
-- ================================================================
json.parse('{"x":1}')                    -- @{x|1}
json.to_str(@{x|1})                      -- "{\n  \"x\": 1\n}"
json.to_compact(@{x|1})                  -- "{\"x\":1}"

-- ================================================================
-- csv — CSV
-- ================================================================
csv.parse("name,age\nAda,30")            -- @[@{name|"Ada" age|30}]
csv.to_str(@[@{x|1 y|2}])               -- "x,y\n1,2"

-- ================================================================
-- yaml — YAML
-- ================================================================
yaml.parse("name: Ada\nage: 30")         -- @{name|"Ada" age|30}
yaml.to_str(@{x|1})                      -- "x: 1"

-- ================================================================
-- fs — File System
-- ================================================================
fs.read("file.txt")                       -- file contents as str
fs.write("file.txt", "content")           -- write string to file
fs.exists("file.txt")                     -- tr/fl
fs.list(".")                              -- @[file1 file2 ...]
fs.mkdir("dir/subdir")                    -- create directories
fs.remove("file.txt")                     -- delete file
fs.stat("file.txt")                       -- @{size|N is_file|tr is_dir|fl modified|N}

-- ================================================================
-- env — Environment Variables
-- ================================================================
env.get("KEY")                            -- value or nl
env.get("KEY", "default")                 -- value or "default"
env.set("KEY", "value")                   -- set env var
env.has("KEY")                            -- tr/fl
env.load(".env")                          -- load .env file
env.all()                                 -- all env vars as map

-- ================================================================
-- proc — Process / Shell
-- ================================================================
proc.exec("ls -la")                       -- run command, return stdout
proc.cwd()                                -- current working directory
proc.platform                             -- "win32" / "linux" / "darwin"
proc.args                                 -- command-line arguments
proc.pid                                  -- process ID
proc.exit(0)                              -- exit with code

-- ================================================================
-- crypto — Cryptography
-- ================================================================
crypto.sha256("data")                     -- 64-char hex hash
crypto.sha512("data")                     -- 128-char hex hash
crypto.md5("data")                        -- 32-char hex hash
crypto.hmac("data", "key")                -- HMAC-SHA256
crypto.hmac("data", "key", "sha512")      -- HMAC with custom algo
crypto.random_bytes(16)                   -- 32-char hex random
crypto.random_int(1, 100)                 -- random integer

-- ================================================================
-- enc — Encoding
-- ================================================================
enc.base64("hello")                       -- aGVsbG8=
enc.base64_decode("aGVsbG8=")             -- hello
enc.url_encode("a b")                     -- a%20b
enc.url_decode("a%20b")                   -- a b
enc.hex("AB")                             -- 4142
enc.hex_decode("4142")                    -- AB

-- ================================================================
-- uuid — UUID Generation
-- ================================================================
uuid.v4()                                 -- random UUID v4

-- ================================================================
-- re — Regular Expressions
-- ================================================================
re.test("^[0-9]+$", "123")               -- tr
re.match("(\\d+)", "abc123")              -- @[123 123]
re.replace("hello", "l", "r")            -- herro
re.split("a1b2c", "[0-9]")               -- @[a b c]
re.find_all("[0-9]+", "a1b22c3")          -- @[1 22 3]

-- ================================================================
-- url — URL Parsing
-- ================================================================
url.parse("https://api.com:8080/v1?q=x")  -- @{protocol|https host|... path|/v1 ...}
url.build(@{protocol|"https" host|"api.com" path|"/v1"})  -- https://api.com/v1

-- ================================================================
-- log — Structured Logging
-- ================================================================
log.debug("detail")                       -- [DEBUG] 10:30:00 detail
log.info("message")                       -- [INFO]  10:30:00 message
log.warn("warning")                       -- [WARN]  10:30:00 warning
log.error("error!")                       -- [ERROR] 10:30:00 error!
log.level("info")                         -- set minimum level

-- ================================================================
-- stream — Reactive Streams
-- ================================================================
lt s = stream.from(@[1 2 3])
s.map(|x| -> x * 2)                      -- transform
s.filter(|x| -> x > 2)                   -- filter
s.reduce(|a, x| -> a + x, 0)             -- aggregate
s.batch(2)                                -- group into chunks
s.take(3)                                 -- first N
s.skip(2)                                 -- skip N
s.collect()                               -- get final list
s.count()                                 -- get count
stream.range(0, 10)                       -- numeric stream

-- ================================================================
-- mem — Memory System
-- ================================================================
-- mem.w (working — volatile)
mem.w.set("key", "val")
mem.w.get("key")
mem.w.has("key")
mem.w.delete("key")
mem.w.keys()
mem.w.clear()

-- mem.s (semantic — persistent facts)
mem.s.store("key", value)
mem.s.recall("key")
mem.s.has("key")
mem.s.search("query", 5)
mem.s.keys()

-- mem.e (episodic — event log)
mem.e.log(@{event|"x"})
mem.e.last(10)
mem.e.all()
mem.e.len()
mem.e.clear()

-- mem.p (procedural — learned functions)
mem.p.learn("name", |x| -> x)
mem.p.use("name")
mem.p.has("name")
mem.p.list()

-- ================================================================
-- web — HTTP Server
-- ================================================================
web.route("GET", "/path", |req| -> web.json(@{ok|tr}))
web.route("POST", "/path", |req| -> web.json(req.body))
web.json(data)                            -- JSON response
web.json(data, 201)                       -- with status code
web.html("<h1>Hi</h1>")                  -- HTML response
web.redirect("/new")                      -- 302 redirect
web.serve(3000)                           -- start server
web.stop()                                -- stop server

-- ================================================================
-- db — Database (SQLite)
-- ================================================================
lt store = db.open("sqlite:app.db")
store.exec("CREATE TABLE ...")            -- execute SQL
store.exec("INSERT ... VALUES (?, ?)", @[val1 val2])  -- parameterized
store.query("SELECT * FROM ...")          -- returns list of maps
store.get("SELECT ... LIMIT 1")           -- returns single map or nl
store.close()                             -- close connection

-- ================================================================
-- ai — AI / LLM Gateway
-- ================================================================
ai.ask("prompt", @{model|"claude"})       -- call LLM
ai.auto("prompt")                         -- auto-select model
ai.models()                               -- list available models
ai.token_count("text")                    -- estimate token count

-- ================================================================
-- kode — Runtime / Meta
-- ================================================================
kode.eval("lt x = 1 + 2")                -- execute code string
kode.parse("lt x = 1")                   -- parse to AST
kode.version                              -- "0.1.0"
kode.feedback("message")                  -- send feedback
kode.suggest("feature idea")              -- suggest feature

-- ================================================================
-- Built-in Functions (top-level)
-- ================================================================
len(@[1 2 3])                             -- 3 (length of list/str/map)
type(42)                                  -- "num" (type name)
assert(tr)                                -- pass if truthy
assert_eq(1, 1)                           -- pass if equal
assert_ne(1, 2)                           -- pass if not equal
