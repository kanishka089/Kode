{
  "scopeName": "source.kode",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#constants" },
    { "include": "#functions" },
    { "include": "#toon" },
    { "include": "#test" },
    { "include": "#decorators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-dash.kode", "match": "--.*$" },
        { "name": "comment.block.kode", "begin": "-\\*", "end": "\\*-" }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.kode",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": [{ "include": "#interpolation" }]
        },
        {
          "name": "string.quoted.double.kode",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "include": "#interpolation" },
            { "name": "constant.character.escape.kode", "match": "\\\\[nrt\\\\\"'0]" }
          ]
        },
        { "name": "string.quoted.single.kode", "begin": "'", "end": "'" }
      ]
    },
    "interpolation": {
      "name": "meta.interpolation.kode",
      "begin": "\\$\\{",
      "end": "\\}",
      "beginCaptures": { "0": { "name": "punctuation.definition.interpolation.begin.kode" } },
      "endCaptures": { "0": { "name": "punctuation.definition.interpolation.end.kode" } },
      "patterns": [{ "include": "source.kode" }]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.hex.kode", "match": "\\b0[xX][0-9a-fA-F_]+\\b" },
        { "name": "constant.numeric.binary.kode", "match": "\\b0[bB][01_]+\\b" },
        { "name": "constant.numeric.octal.kode", "match": "\\b0[oO][0-7_]+\\b" },
        { "name": "constant.numeric.float.kode", "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9]+)?\\b" },
        { "name": "constant.numeric.integer.kode", "match": "\\b[0-9][0-9_]*\\b" }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.kode",
          "match": "\\b(if|ef|el|wl|lp|fr|mt|br|nx|rt|tx|ct|fy|tw)\\b"
        },
        {
          "name": "keyword.declaration.kode",
          "match": "\\b(lt|vr|fn|ag|tk|st|en|it|sv|ext|get|im|ex)\\b"
        },
        {
          "name": "keyword.agent.kode",
          "match": "\\b(sp|em|on|aw|go|ch|mem)\\b"
        },
        {
          "name": "keyword.safety.kode",
          "match": "\\b(allow|deny|budget|ensure|checkpoint|rollback)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        { "name": "constant.language.boolean.true.kode", "match": "\\btr\\b" },
        { "name": "constant.language.boolean.false.kode", "match": "\\bfl\\b" },
        { "name": "constant.language.null.kode", "match": "\\bnl\\b" }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.pipe.kode", "match": "\\|>" },
        { "name": "keyword.operator.arrow.kode", "match": "->" },
        { "name": "keyword.operator.spread.kode", "match": "\\.\\.\\." },
        { "name": "keyword.operator.range.kode", "match": "\\.\\." },
        { "name": "keyword.operator.nullcoalesce.kode", "match": "\\?\\?" },
        { "name": "keyword.operator.optchain.kode", "match": "\\?\\." },
        { "name": "keyword.operator.type.kode", "match": "::" },
        { "name": "keyword.operator.comparison.kode", "match": "[=!<>]=|[<>]" },
        { "name": "keyword.operator.assignment.kode", "match": "[+\\-*/]=" },
        { "name": "keyword.operator.power.kode", "match": "\\*\\*" }
      ]
    },
    "functions": {
      "patterns": [
        { "name": "entity.name.function.kode", "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)", "captures": { "1": { "name": "keyword.declaration.kode" }, "2": { "name": "entity.name.function.kode" } } },
        { "name": "entity.name.type.kode", "match": "\\b(ag|st|en|it|sv)\\s+([A-Z][a-zA-Z0-9_]*)", "captures": { "1": { "name": "keyword.declaration.kode" }, "2": { "name": "entity.name.type.kode" } } }
      ]
    },
    "toon": {
      "patterns": [
        { "name": "punctuation.definition.toon.map.kode", "match": "@\\{" },
        { "name": "punctuation.definition.toon.list.kode", "match": "@\\[" }
      ]
    },
    "test": {
      "patterns": [
        { "name": "keyword.other.test.kode", "match": "#test" }
      ]
    },
    "decorators": {
      "patterns": [
        { "name": "meta.decorator.kode", "match": "@[a-zA-Z_][a-zA-Z0-9_]*" }
      ]
    }
  }
}
